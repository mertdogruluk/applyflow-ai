// ApplyFlow AI — Prisma Schema
// Docs: https://pris.ly/d/prisma-schema

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider   = "postgresql"
  url        = env("DATABASE_URL")
  extensions = [vector]
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum ApplicationStatus {
  WISHLIST
  APPLIED
  ASSESSMENT
  INTERVIEW
  OFFER
  REJECTED
  ACCEPTED
  WITHDRAWN
}

enum WorkType {
  REMOTE
  HYBRID
  ON_SITE
}

enum JobType {
  FULL_TIME
  PART_TIME
  INTERNSHIP
  CONTRACT
  FREELANCE
}

enum ReminderStatus {
  PENDING
  DONE
  DISMISSED
}

/// LLM-as-a-Judge bir (Job, Project) çifti için kategorik karar verir.
/// fitScore'un yanında saklanır; UI'da rozet / filtre olarak kullanılır.
enum MatchVerdict {
  STRONG_FIT
  MODERATE_FIT
  WEAK_FIT
  NOT_RELEVANT
}

// ─── Models ──────────────────────────────────────────────────────────────────

/// Bir iş veya staj başvurusunu temsil eder.
/// userId, Clerk tarafından yönetilen kullanıcıya aittir; ayrı User modeli yoktur.
model Job {
  id       String @id @default(cuid())
  userId   String // Clerk userId — veri izolasyonu bu alan üzerinden sağlanır

  title    String
  company  String
  location String?

  workType WorkType          @default(HYBRID)
  jobType  JobType           @default(FULL_TIME)
  status   ApplicationStatus @default(WISHLIST)

  jobUrl      String?
  salary      String?
  notes       String?
  source      String?  // Kaynak: LinkedIn, Indeed, Referral vb.
  description String?  // İş ilanı açıklaması
  cvVersion   String?  // Gönderilen CV versiyonu
  coverLetter String?  // Kapak mektubu metni

  appliedAt DateTime?
  deadline  DateTime?

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Vector matching alanları ─────────────────────────────────────────────
  // Prisma pgvector'ü native desteklemez → Unsupported + $queryRaw.
  // Gemini text-embedding-004 = 768 boyut. Modeli değiştirirsen migration gerekir.
  embedding  Unsupported("vector(768)")?
  embeddedAt DateTime? // son embedding üretim zamanı (updatedAt > embeddedAt ise bayat)

  // İlişkiler
  projects  JobProject[]
  analysis  AiAnalysis?
  reminders Reminder[]
  matches   MatchResult[]

  @@index([userId])
}

/// Kullanıcının GitHub veya portfolio projesini temsil eder.
/// Birden fazla iş başvurusuna bağlanabilir (many-to-many via JobProject).
model Project {
  id          String  @id @default(cuid())
  userId      String // Clerk userId

  name        String
  description String?
  githubUrl   String?
  liveUrl     String?
  techStack   String[] // Örn: ["Next.js", "TypeScript", "PostgreSQL"]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  // ─── Vector matching alanları ─────────────────────────────────────────────
  // Aynı boyut (768) ve aynı model ile üretilmek zorunda; aksi halde cosine
  // benzerliği anlamsızlaşır. Embedding üretimi lib/ai/embeddings.ts'de.
  embedding  Unsupported("vector(768)")?
  embeddedAt DateTime?

  // İlişkiler
  jobs    JobProject[]
  matches MatchResult[]

  @@index([userId])
}

/// Job ile Project arasındaki many-to-many ilişki tablosu.
/// "Bu proje hangi başvurularda kullanıldı?" sorusunu yanıtlar.
model JobProject {
  jobId     String
  projectId String

  createdAt DateTime @default(now())

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@id([jobId, projectId])
}

/// Bir iş başvurusu için üretilen yapay zeka analiz sonucunu temsil eder.
/// Her Job'un en fazla bir AiAnalysis'i olabilir (1-to-1).
model AiAnalysis {
  id    String @id @default(cuid())
  jobId String @unique // 1 job → 1 analysis

  summary     String?
  matchScore  Int? // 0–100 arası uyum puanı
  strengths   String[]
  weaknesses  String[]
  suggestions String[]
  rawResult   Json? // API'den gelen ham yanıt

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)
}

/// Vector retrieval + LLM-as-a-Judge sonucunda üretilen eşleştirme kaydı.
/// Bir job için 0..N MatchResult olabilir (her aday proje için bir tane).
/// JobProject ile karıştırılmamalı: JobProject = "bu projeyi başvuruda kullandım",
/// MatchResult = "AI bu projenin bu işe uyduğunu söyledi".
model MatchResult {
  id        String @id @default(cuid())
  jobId     String
  projectId String

  /// LLM-as-a-Judge'ın holistik puanı (0-100). Genellikle UI'da gösterilen budur.
  fitScore Int
  /// Vector retrieval'dan gelen ham cosine benzerliği (0-1). Debug + sıralama için.
  similarity Float
  verdict    MatchVerdict
  /// Judge'ın gerekçesi — kullanıcıya gösterilir.
  reasoning  String
  strengths  String[]
  gaps       String[]
  /// LLM'in döndürdüğü ham JSON yanıtı (audit + reproducibility).
  rawResult  Json?

  judgedAt DateTime @default(now())

  job     Job     @relation(fields: [jobId], references: [id], onDelete: Cascade)
  project Project @relation(fields: [projectId], references: [id], onDelete: Cascade)

  /// Aynı (job, project) çifti yeniden yargılanırsa upsert için anahtar.
  @@unique([jobId, projectId])
  @@index([jobId])
  @@index([projectId])
}

/// Bir iş başvurusuna bağlı hatırlatıcıyı temsil eder.
model Reminder {
  id    String @id @default(cuid())
  jobId String

  title  String
  dueAt  DateTime
  status ReminderStatus @default(PENDING)

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  job Job @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId])
}
