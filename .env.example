# ──────────────────────────────────────────────────────────────────────────────
# ApplyFlow AI — environment variables (template)
# Copy this file to `.env` and fill in your own values. Never commit `.env`.
# ──────────────────────────────────────────────────────────────────────────────

# PostgreSQL connection string used by Prisma.
# Local Postgres example:
#   postgresql://USER:PASSWORD@localhost:5432/applyflow_ai
DATABASE_URL=""

# Clerk authentication keys — get these from https://dashboard.clerk.com
NEXT_PUBLIC_CLERK_PUBLISHABLE_KEY=""
CLERK_SECRET_KEY=""

# Where Clerk should redirect after signing in / up
NEXT_PUBLIC_CLERK_SIGN_IN_URL=/sign-in
NEXT_PUBLIC_CLERK_SIGN_UP_URL=/sign-up
NEXT_PUBLIC_CLERK_SIGN_IN_FALLBACK_REDIRECT_URL=/dashboard
NEXT_PUBLIC_CLERK_SIGN_UP_FALLBACK_REDIRECT_URL=/dashboard

# Google Gemini API key — server-side only (never NEXT_PUBLIC_).
# Get one at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=""

# Public base URL of the deployed app (used in metadata + share links).
NEXT_PUBLIC_APP_URL="http://localhost:3000"
